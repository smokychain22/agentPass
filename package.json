    "api": "node server.js",
    "test": "node test/smoke.js && node test/next-api.test.js && node test/unified-diff.test.js && tsx test/workspace.test.ts",
    "test:api": "node test/smoke.js",
    "test:next": "node test/next-api.test.js",
    "test:production": "tsx scripts/production-smoke-test.ts",
    "verify:okx": "tsx scripts/verify-okx-integration.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.2.0",
