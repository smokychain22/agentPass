    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "execa": "^9.6.1",
    "express": "^5.2.1",
    "fs-extra": "^11.3.6",
    "geist": "^1.3.1",
    "jscpd": "^5.0.12",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "knip": "^6.25.0",
    "lucide-react": "^0.525.0",
    "madge": "^8.0.0",
    "nanoid": "^5.1.16",
    "next": "^15.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "simple-git": "^3.27.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.24.2"
  },
