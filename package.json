{
  "name": "repodiet",
  "version": "1.0.0",
  "description": "RepoDiet — cut AI code bloat before your app collapses",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
