# Copy to .env.local for local development — never commit real values.

# --- Agentic Wallet (ASP identity + receive payments) ---
OKX_AGENTIC_WALLET_ADDRESS=0xYourAgenticWalletEvmAddress
PAY_TO_ADDRESS=0xYourAgenticWalletEvmAddress
REPODIET_PAY_TO=0xYourAgenticWalletEvmAddress

# Returned after OKX ASP registration (not hand-created)
OKX_ASP_AGENT_ID=5283
OKX_A2A_SERVICE_ID=32947
OKX_A2MCP_SERVICE_ID=32948
NEXT_PUBLIC_OKX_ASP_AGENT_ID=5283

# Public OKX.AI agent page — set only when the listing is public (currently ASP 5283 may 404).
# Example: https://www.okx.ai/agents/5283
NEXT_PUBLIC_OKX_AGENT_URL=
# Optional: auto-build URL from ASP id (off by default — do not assume listing is public)
# NEXT_PUBLIC_OKX_AGENT_URL_AUTO=1

# --- OKX Developer API (server only — x402 Payment SDK) ---
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# --- Payment environment (testnet | production) ---
# Preview/staging MUST use testnet. Do not switch Vercel production to mainnet in this PR.
# REPODIET_PAYMENT_ENV=testnet
# REPODIET_PAYMENT_MODE=testnet
# REPODIET_PAYMENT_NETWORK=eip155:1952
# REPODIET_PAYMENT_CHAIN_ID=1952
# REPODIET_PAYMENT_ASSET=0x9e29b3aada05bf2d2c827af80bd28dc0b9b4fb0c
# Production marketplace (X Layer mainnet) — owner approval required before enabling:
# REPODIET_PAYMENT_ENV=production
# REPODIET_PAYMENT_NETWORK=eip155:196
# REPODIET_PAYMENT_CHAIN_ID=196
# REPODIET_PAYMENT_ASSET=0x779ded0c9e1022225f8e0630b35a9b54be713736

# --- x402 production ---
REQUIRE_REAL_X402=1
REPODIET_OKX_A2MCP_PAID=1
# REPODIET_X402_FACILITATOR_URL=https://your-facilitator.example
# X Layer RPC used for direct-site on-chain USDT Transfer verification
# XLAYER_RPC_URL=https://rpc.xlayer.tech

# Never expose internal E2E buyer to customers / NEXT_PUBLIC_*
# Spelling is ALLOW_INTERNAL_TEST_BUYER (not BUER). Keep =0 in production after acceptance.
ALLOW_INTERNAL_TEST_BUYER=0
# REPODIET_TEST_BUYER_ADDRESS=
# Default Fix & PR test-mode buyer (OKX Agentic Wallet for owner email)
# NEXT_PUBLIC_REPODIET_OWNER_BUYER_WALLET=0xaa895234c3fc31c40018eef975db6ac79bf87f1a
# --- GitHub App ---
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY_BASE64=
# GITHUB_APP_WEBHOOK_SECRET=
# GITHUB_WEBHOOK_SECRET=

# --- Persistence ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Operator receipt trust root (RSA-SHA256) ---
# Private key signs receipts / binding attestations in production. Prefer PEM or base64 PEM.
# REPODIET_OPERATOR_PRIVATE_KEY=
# Green PR protocol (A2A delivery proof) — separate from operator commerce receipts.
# REPODIET_RECEIPT_PRIVATE_KEY=
# REPODIET_GREEN_PR_PRIVATE_KEY=
# Public key used for independent cryptographic verification (REQUIRED pin for production).
# Production does NOT derive the verifier key from the private key.
# If unset in production, the repo-pinned SPKI public key is used (see pinned-operator-public-key.ts).
# Dashboard: Project Settings → Environment Variables → REPODIET_OPERATOR_PUBLIC_KEY → Production → paste SPKI PEM → redeploy
# REPODIET_OPERATOR_PUBLIC_KEY=
# Inspect published trust root: GET /api/okx/trust-root
# Fingerprint: sha256:d495f62bd74d136390322df4a042db4250cd27c594992b55f321201a16aba662

# --- Optional ---
GEMINI_API_KEY=
EARN_WORKER_SECRET=
EARN_WORKER_URL=

# --- Local / temporary controlled A2A acceptance only ---
# Enable only for the single funded A2A acceptance run, then REMOVE from Vercel Production:
#   REPODIET_A2A_TEST_PRICE
#   REPODIET_X402_TEST_MODE
#   REPODIET_X402_TEST_SECRET
# Retain ALLOW_INTERNAL_TEST_BUYER=0 after that pass.
# REPODIET_A2A_TEST_PRICE=1
# REPODIET_X402_TEST_MODE=1
# REPODIET_X402_TEST_SECRET=
