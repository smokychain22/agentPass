# Copy to .env.local for local development — never commit real values.

# --- Agentic Wallet (ASP identity + receive payments) ---
OKX_AGENTIC_WALLET_ADDRESS=0xYourAgenticWalletEvmAddress
PAY_TO_ADDRESS=0xYourAgenticWalletEvmAddress
REPODIET_PAY_TO=0xYourAgenticWalletEvmAddress

# Returned after OKX ASP registration (not hand-created)
OKX_ASP_AGENT_ID=5283
OKX_A2A_SERVICE_ID=32947
OKX_A2MCP_SERVICE_ID=32948
NEXT_PUBLIC_OKX_ASP_AGENT_ID=5283

# Public OKX.AI agent page — set only when the listing is public (currently ASP 5283 may 404).
# Example: https://www.okx.ai/agents/5283
NEXT_PUBLIC_OKX_AGENT_URL=
# Optional: auto-build URL from ASP id (off by default — do not assume listing is public)
# NEXT_PUBLIC_OKX_AGENT_URL_AUTO=1

# --- OKX Developer API (server only — x402 Payment SDK) ---
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# --- x402 production ---
REQUIRE_REAL_X402=1
REPODIET_OKX_A2MCP_PAID=1
# REPODIET_X402_FACILITATOR_URL=https://your-facilitator.example
# X Layer RPC used for direct-site on-chain USDT Transfer verification
# XLAYER_RPC_URL=https://rpc.xlayer.tech

# Never expose internal E2E buyer to customers / NEXT_PUBLIC_*
# ALLOW_INTERNAL_TEST_BUYER=0
# REPODIET_TEST_BUYER_ADDRESS=
# --- GitHub App ---
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY_BASE64=
# GITHUB_APP_WEBHOOK_SECRET=
# GITHUB_WEBHOOK_SECRET=

# --- Persistence ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Optional ---
GEMINI_API_KEY=
EARN_WORKER_SECRET=
EARN_WORKER_URL=

# --- Local / test only ---
# REPODIET_X402_TEST_MODE=1
# REPODIET_X402_TEST_SECRET=
